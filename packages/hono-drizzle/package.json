{
  "name": "hono-drizzle",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "imports": {
    "#/*": "./dist/*"
  },
  "scripts": {
    "prebuild": "rimraf dist tsconfig.tsbuildinfo",
    "build": "tsc --build tsconfig.json",
    "format": "prettier --check \"{src,test}/**/*.ts\"",
    "format:fix": "prettier --write \"{src,test}/**/*.ts\"",
    "lint": "eslint --cache \"{src,test}/**/*.ts\"",
    "lint:fix": "eslint --cache \"{src,test}/**/*.ts\" --fix",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "dotenv -e .env.local -- drizzle-kit migrate",
    "db:push": "dotenv -e .env.local -- drizzle-kit push",
    "start:shopping:local": "node --env-file=.env.local dist/entryPoint/primary/shopping/web/main.js",
    "test": "dotenv -e .env.test -- vitest --typecheck",
    "test:cov": "dotenv -e .env.test -- vitest --coverage",
    "test:db": "dotenv -e .env.test.db -- vitest --no-file-parallelism",
    "test:db:migrate": "dotenv -e .env.test.db -- drizzle-kit migrate",
    "test:db:push": "dotenv -e .env.test.db -- drizzle-kit push"
  },
  "dependencies": {
    "@hono/node-server": "1.19.14",
    "@hono/zod-openapi": "1.2.4",
    "@scalar/hono-api-reference": "0.10.7",
    "date-fns": "4.1.0",
    "dotenv": "17.4.1",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.14",
    "neverthrow": "8.2.0",
    "pg": "8.20.0",
    "remeda": "2.33.7",
    "typed-inject": "5.0.0",
    "ulidx": "2.4.1",
    "yargs": "18.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "24.12.2",
    "@types/pg": "8.20.0",
    "@types/yargs": "^17.0.35",
    "@vitest/coverage-v8": "3.2.4",
    "@vitest/ui": "3.2.4",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "0.31.10",
    "eslint-plugin-neverthrow": "1.1.4",
    "eslint-plugin-no-relative-import-paths": "1.6.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "rimraf": "6.1.3",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "3.2.4"
  }
}
